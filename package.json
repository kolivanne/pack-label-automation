  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "csv-parse": "^5.5.0",
    "handlebars": "^4.7.9",
    "p-limit": "^7.3.0",
    "puppeteer": "^22.0.0"
  },
  "devDependencies": {
    "@vitest/ui": "^4.1.5",
    "rimraf": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
